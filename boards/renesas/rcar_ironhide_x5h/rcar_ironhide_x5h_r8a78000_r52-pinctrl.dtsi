#include <zephyr/dt-bindings/pinctrl/renesas/pinctrl-r8a78000.h>

&pfc {
	can0_rx_default: can0_rx_default {
		pin = <PIN_CAN0RX_INTP0 FUNC_CAN0RX_INTP0>;
	};

	can0_tx_default: can0_tx_default {
		pin = <PIN_CAN0TX FUNC_CAN0TX>;
	};

	can1_rx_default: can1_rx_default {
		pin = <PIN_CAN1RX_INTP1 FUNC_CAN1RX_INTP1>;
	};

	can1_tx_default: can1_tx_default {
		pin = <PIN_CAN1TX FUNC_CAN1TX>;
	};

	can5_rx_default: can5_rx_default {
		pin = <PIN_CAN5RX_INTP5 FUNC_CAN5RX_INTP5>;
	};

	can5_tx_default: can5_tx_default {
		pin = <PIN_CAN5TX FUNC_CAN5TX>;
	};

	hscif1_data_tx_default: hscif1_data_tx_default {
		pin = <PIN_HTX1 FUNC_HTX1>;
	};

	hscif1_data_rx_default: hscif1_data_rx_default {
		pin = <PIN_HRX1 FUNC_HRX1>;
	};

	gpio0_3_default: gpio0_3_default {
		pin = <PIN_STPWT_EXTFXR>;
		bias-disable;
	};

	gpio9_1_default: gpio9_1_default {
		pin = <PIN_ETHES0_CAPTURE>;
		bias-disable;
	};

	gpio9_2_default: gpio9_2_default {
		pin = <PIN_ETHES0_MATCH>;
		bias-disable;
	};

	gpio9_3_default: gpio9_3_default {
		pin = <PIN_ETHES4_PPS>;
		bias-disable;
	};

	gpio9_4_default: gpio9_4_default {
		pin = <PIN_ETHES4_CAPTURE>;
		bias-disable;
	};

	gpio9_5_default: gpio9_5_default {
		pin = <PIN_ETHES4_MATCH>;
		bias-disable;
	};

	i2c5_scl_default: i2c5_scl_default {
		pin = <PIN_SCL5 FUNC_SCL5>;
	};

	i2c5_sda_default: i2c5_sda_default {
		pin = <PIN_SDA5 FUNC_SDA5>;
	};
};
